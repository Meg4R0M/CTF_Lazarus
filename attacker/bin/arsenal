#!/bin/bash
# arsenal — liste les outils disponibles sur le poste

cat <<'EOF'

  ▲ ARSENAL DISPONIBLE — Poste de pentest Humanix

  ────────────────────────────────────────────────────────────────────────
  RECON & ENUMERATION
    nmap                    Scan de ports
    nxc smb|ldap|winrm ...  NetExec (ex-CrackMapExec) — couteau suisse AD
    ldapsearch              Requêtes LDAP brutes
    smbclient               Client SMB interactif / listing de shares
    dig                     Requêtes DNS

  KERBEROS / AD ATTACK
    impacket-GetUserSPNs    Lister les SPN d'un domaine (le -request bug
                            sur Samba — utilise kerberoast à la place)
    kerberoast              Helper local : extrait un TGS crackable depuis
                            le ccache (workflow : kinit -> kvno SPN -> kerberoast SPN)
    impacket-secretsdump    Dump NTDS.dit / hashes
    impacket-psexec         Exécution distante via SMB
    impacket-wmiexec        Exécution distante via WMI
    net rpc password ...    Reset de mot de passe via SAMR (ACL abuse)
    kinit / klist / kvno    Auth Kerberos + listing + demande de TGS

  CRACK
    john                    Cassage offline (AS-REP, TGS, NTLM...)
                            Wordlist d'amorçage : /opt/wordlist.txt

  BLOODHOUND
    bloodhound-python       Collecteur depuis Linux
                            (l'analyse graphique se fait dans ton BloodHound local
                             — récupère le .zip généré et importe-le)

  UTILS
    curl, wget              HTTP client
    git, vim, less          Confort shell
    ip a, ping, ncat        Network basics

  ────────────────────────────────────────────────────────────────────────
  Tape :  briefing   pour relire la mission
          targets    pour voir les cibles et leurs IP
          arsenal    pour réafficher cet écran

EOF
